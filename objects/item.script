local item_db = require "objects.items"

go.property("item_id", hash("stick"))



function init(self)
	
	
	print("ID:", self.item_id)

	local data = item_db.items[self.item_id]

	if not data then
		print("Item nicht gefunden:", self.item_id)
		return
	end

	self.data = data 
	
	-- Sprite setzen
	sprite.play_flipbook("#sprite", self.data.sprite)

	-- Beispiel
	print("Name:", self.data.name)
end

