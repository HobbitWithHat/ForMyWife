	-- Remove this function if not needed
end
--[[
function update(self, dt)
	if self.moving then
		if is_walkable() then

			pos = go.get_position()
			dir = self.goal - pos
			distance = vmath.length(dir)
			step = self.speed * dt
			
			if distance <= step then
				go.set_position(self.goal)
				self.moving = false
			else
				dir = vmath.normalize(dir)
				pos = pos + dir * step
				go.set_position(pos)
			end
		end
	end
end
]]


