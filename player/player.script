function on_input(self, action_id, action)
	if action_id == hash("touch") and action.pressed then
		-- speichert Klickpoition als vektor
		local action = vmath.vector3(action.x, action.y, 0)

		-- berechnet Tile und Position des Ziels
		self.t_tile = {get_tile(action)[1], get_tile(action)[2]}
		self.t_pos = get_tile_position(self.t_tile)
		print("Go to " .. self.t_tile[1], self.t_tile[2])	
		print("That's at ".. self.t_pos)
		
		--startet Bewegung
		self.moving = true

		local path = path_from_to(self.t_tile, self.p_tile)
	end
end

