	-- Remove this function if not needed
end

function on_input(self, action_id, action)
	if action_id == hash("touch") and action.pressed then
		--rechnet Klickposition in Tile um
		tile_x = math.floor(action.x / tile_size) + 1
		tile_y = math.floor(action.y / tile_size) + 1
		print ("Go to Tile " .. tile_x, tile_y)

		-- ermittelt Mittelpunkt des angeklickten Tiles
		local world_x = (tile_x - 0.5) * tile_size
		local world_y = (tile_y - 0.5) * tile_size
		
		--Setzt Mittelpunkt des angeklickten Tiles als Ziel
		self.goal.x = world_x
		self.goal.y = world_y
		self.goal.z = 0.1
		print("Go to " .. tile_x, tile_y)		
		
		--startet Bewegung
		self.moving = true
		
		
	end
end

