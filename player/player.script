function on_message(self, message_id, message, sender)
	-- Add message-handling code here
	-- Learn more: https://defold.com/manuals/message-passing/
	-- Remove this function if not needed
end

function on_input(self, action_id, action)
	if action_id == hash("touch") and action.pressed then
		
		tile_x, tile_y = get_tile(action.x, action.y)
		local wx, wy = get_tile_position(tile_x, tile_y)

		
		
		--Setzt Mittelpunkt des angeklickten Tiles als Ziel
		self.target_tile = {tile_x, tile_y}
		self.goal = vmath.vector3(wx, wy, 0.1)
		print("Go to " .. self.target_tile[1], self.target_tile[2])		
		
		--startet Bewegung
		self.moving = true
		
		
	end
end

