require "main.pathfinding"
local cursor = require "in.cursor"


local dir
local distance
local step



function init(self)
	msg.post(".", "acquire_input_focus")

	-- Spieler Attribute und Werte
	self.speed = 100
	self.hunger = 100
	self.sleep = 100

	--Werte zum Pathfinding und Bewegung
	self.moving = false
	self.p_tile = {0, 0}
	self.p_pos = vmath.vector3(0, 0, 0.1)
	self.t_tile = {0, 0}
	self.t_pos = vmath.vector3()


	-- Initialisiere Startposition, berechnet erstes Tile der Spielerposition
	self.p_pos = go.get_position()
	self.p_tile = get_tile(self.p_pos)
	self.p_pos = get_tile_position(self.p_tile)

	-- Setzt Spieler auf erstes Tile
	go.set_position(self.p_pos)

end

function final(self)
	-- Add finalization code here
